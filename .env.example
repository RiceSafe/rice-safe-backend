# Database Configuration
# Default postgres user/pass for local docker compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ricesafe

# Database Connection String for the Go application (Run locally)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DB_SOURCE=postgresql://postgres:postgres@localhost:5432/ricesafe?sslmode=disable

# Security
# REQUIRED: Change this to a strong random string in producton!
# You can generate one with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-secure-secret-key

# Google Cloud Storage
GCS_BUCKET_NAME=ricesafe-dev-uploads
GCS_CREDENTIALS_FILE=service-account.json

# Google OAuth Keys
GOOGLE_CLIENT_ID_WEB=xxxxx-web.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=xxxxx-ios.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=xxxxx-android.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# LINE OAuth
LINE_CHANNEL_ID=your_line_channel_id_here

# Server Port
PORT=8080

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_PORT=8000

# Open Weather Map Key
OPEN_WEATHER_MAP_KEY=change-me-to-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather

# Email (Resend)
# Sign up at https://resend.com — free tier available
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com